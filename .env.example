# --- Security ---

# Generate secure values with:
#   openssl rand -base64 32

# HMAC-SHA256 signing key for JWT access tokens (≥ 32 bytes required)
JWT_SECRET=CHANGE_ME_IN_PRODUCTION

# Base64-encoded AES key for OAuth token encryption at rest
# Must decode to 16 (AES-128), 24 (AES-192), or 32 (AES-256) bytes
OAUTH_TOKEN_ENCRYPTION_KEY_BASE64=CHANGE_ME_IN_PRODUCTION

# --- Database ---

SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/nextdocs
SPRING_DATASOURCE_USERNAME=nextdocs
SPRING_DATASOURCE_PASSWORD=nextdocs

# --- JWT expiry ---

JWT_ACCESS_EXPIRY_MS=900000
JWT_REFRESH_EXPIRY_MS=604800000

# --- CORS & cookies ---

CORS_ALLOWED_ORIGINS=http://localhost:3000
# Set to true behind HTTPS in production
COOKIE_SECURE=false
